{
  "name": "tahaqaq",
  "private": true,
  "packageManager": "bun@1.3.10",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "bun run --env-file=.env --cwd apps/web dev",
    "dev:mobile": "bun run --env-file=.env --cwd apps/mobile dev",
    "dev:convex": "cd packages/convex && ln -sf ../../.env .env.local && bunx convex dev",
    "setup:convex": "cd packages/convex && ln -sf ../../.env .env.local && bunx convex dev --once",
    "build:web": "bun run --env-file=.env --cwd apps/web build",
    "lint:web": "bun run --env-file=.env --cwd apps/web lint",
    "lint:mobile": "bun run --env-file=.env --cwd apps/mobile lint",
    "typecheck:web": "bun run --env-file=.env --cwd apps/web typecheck",
    "typecheck:mobile": "bun run --env-file=.env --cwd apps/mobile typecheck",
    "typecheck:convex": "bun run --env-file=.env --cwd packages/convex build"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1"
  }
}
