{
  "name": "TAHAQAQ",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "prestart": "node ./scripts/link-root-env.cjs",
    "start": "expo start",
    "predev": "node ./scripts/link-root-env.cjs",
    "dev": "expo start --clear",
    "predev:client": "node ./scripts/link-root-env.cjs",
    "dev:client": "expo start --dev-client",
    "reset-project": "node ./scripts/reset-project.js",
    "preandroid": "node ./scripts/link-root-env.cjs",
    "android": "expo run:android",
    "preios": "node ./scripts/link-root-env.cjs",
    "ios": "expo run:ios",
    "ios:simulator": "expo run:ios",
    "preweb": "node ./scripts/link-root-env.cjs",
    "web": "expo start --web",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "format": "prettier --write ./src",
    "format:check": "prettier --check ./src",
    "typecheck": "tsc --noEmit",
    "version:patch": "npm version patch --no-git-tag-version && echo 'Version bumped (patch)'",
    "version:minor": "npm version minor --no-git-tag-version && echo 'Version bumped (minor)'",
    "version:major": "npm version major --no-git-tag-version && echo 'Version bumped (major)'",
    "postinstall": "npm rebuild @shopify/react-native-skia"
  },
  "dependencies": {
    "@convex-dev/auth": "^0.0.91",
    "@expo/vector-icons": "^15.0.2",
    "@gorhom/bottom-sheet": "^5.2.9",
    "@tahaqaq/assets": "workspace:*",
    "@tahaqaq/mock-data": "workspace:*",
    "convex": "^1.34.1",
    "expo": "^56.0.12",
    "expo-constants": "~56.0.18",
    "expo-dev-client": "~56.0.20",
    "expo-device": "~56.0.4",
    "expo-font": "~56.0.7",
    "expo-glass-effect": "~56.0.4",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.11",
    "expo-linking": "~56.0.14",
    "expo-localization": "^56.0.6",
    "expo-location": "~56.0.18",
    "expo-maps": "^56.0.7",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "heroui-native": "^1.0.4",
    "i18n-js": "^4.5.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-get-random-values": "~1.11.0",
    "react-native-keyboard-controller": "1.21.6",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "uniwind": "^1.6.4"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "babel-preset-expo": "~56.0.0",
    "eslint": "^9.0.0",
    "eslint-config-expo": "~56.0.4",
    "typescript": "~6.0.3"
  },
  "private": true
}
